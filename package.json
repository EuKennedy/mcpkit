{
  "name": "mcpkit",
  "version": "0.1.1",
  "description": "The TypeScript toolkit for building MCP servers without the boilerplate.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agents",
    "llm",
    "tools",
    "typescript",
    "cli",
    "scaffolding"
  ],
  "homepage": "https://github.com/EuKennedy/mcpkit",
  "bugs": {
    "url": "https://github.com/EuKennedy/mcpkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EuKennedy/mcpkit.git"
  },
  "license": "MIT",
  "author": "Kennedy",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "bin": {
    "mcpkit": "./dist/cli.js"
  },
  "files": ["dist", "templates", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "tsx": "^4.21.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
